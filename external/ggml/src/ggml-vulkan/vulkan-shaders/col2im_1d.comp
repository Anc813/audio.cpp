#version 450

#include "types.glsl"

layout (push_constant) uniform parameter
{
    uint T_in;
    uint T_out;
    uint OC;
    uint K;
    uint K_OC;
    int s0;
    int p0;
} p;

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout (binding = 0) readonly buffer X {A_TYPE data_a[];};
layout (binding = 1) writeonly buffer D {D_TYPE data_d[];};

void main() {
    uint idx = gl_GlobalInvocationID.x;
    const uint total = p.T_out * p.OC;
    const uint stride = gl_NumWorkGroups.x * gl_WorkGroupSize.x;

    while (idx < total) {
        const int t_out = int(idx % p.T_out);
        const int oc = int(idx / p.T_out);
        const int t_abs = t_out + p.p0;

        int t_in_min = (t_abs - int(p.K) + p.s0) / p.s0;
        if (t_in_min < 0) {
            t_in_min = 0;
        }
        int t_in_max = t_abs / p.s0;
        if (t_in_max >= int(p.T_in)) {
            t_in_max = int(p.T_in) - 1;
        }

        float sum = 0.0;
        for (int t_in = t_in_min; t_in <= t_in_max; ++t_in) {
            const int k = t_abs - t_in * p.s0;
            sum += float(data_a[uint(oc) * p.K + uint(k) + uint(t_in) * p.K_OC]);
        }

        data_d[idx] = D_TYPE(sum);
        idx += stride;
    }
}
